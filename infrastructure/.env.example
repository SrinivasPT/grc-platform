# GRC Platform — Infrastructure Environment Variables
# Copy this file to .env and fill in real values before running docker-compose
# .env is gitignored — never commit real credentials

# SQL Server
SQLSERVER_SA_PASSWORD=YourGRC!Strong!Passw0rd
SQLSERVER_DB=grcplatform

# Neo4j
NEO4J_AUTH=neo4j/YourNeo4jPassword1

# Redis
REDIS_PASSWORD=YourRedisPassword1

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=YourKeycloakAdminPassword1
KEYCLOAK_HOSTNAME=localhost

# Application DB credentials (separate from SA — least privilege)
GRC_DB_USER=grc_app
GRC_DB_PASSWORD=YourAppDbPassword1

# Vault (optional for local dev — leave blank to skip vault integration)
VAULT_ADDR=
VAULT_TOKEN=
